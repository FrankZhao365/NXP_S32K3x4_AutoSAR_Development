                      </POSSIBLE-ERROR-REFS>
                    </CLIENT-SERVER-OPERATION>
                    <CLIENT-SERVER-OPERATION UUID="cecaf18a-8836-4147-986b-fa1d0f969269">
                      <SHORT-NAME>SelectShutdownCause</SHORT-NAME>
                      <DESC>
                        <L-2 L="FOR-ALL">The SW-C selects the cause corresponding to the next shutdown target.</L-2>
                      </DESC>
                      <ARGUMENTS>
                        <ARGUMENT-DATA-PROTOTYPE UUID="624fe0c8-f7dd-4396-acb2-97f94d4702fd">
                          <SHORT-NAME>shutdownCause</SHORT-NAME>
